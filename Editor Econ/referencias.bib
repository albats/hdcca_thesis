@article{https://doi.org/10.1111/jofi.13199,
  author = {KELLY, BRYAN and MALAMUD, SEMYON and PEDERSEN, LASSE HEJE},
  title = {Principal Portfolios},
  journal = {The Journal of Finance},
  volume = {78},
  number = {1},
  pages = {347-387},
  doi = {https://doi.org/10.1111/jofi.13199},
  url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/jofi.13199},
  eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1111/jofi.13199},
  abstract = {ABSTRACT We propose a new asset pricing framework in which all securities' signals predict each individual return. While the literature focuses on securities' own-signal predictability, assuming equal strength across securities, our framework includes cross-predictability—leading to three main results. First, we derive the optimal strategy in closed form. It consists of eigenvectors of a “prediction matrix,” which we call “principal portfolios.” Second, we decompose the problem into alpha and beta, yielding optimal strategies with, respectively, zero and positive factor exposure. Third, we provide a new test of asset pricing models. Empirically, principal portfolios deliver significant out-of-sample alphas to standard factors in several data sets.},
  year = {2023}
}

